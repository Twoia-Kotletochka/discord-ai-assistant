# Discord bot token from https://discord.com/developers/applications
TZ=Europe/Kyiv
REMINDER_TIME_ZONE=Europe/Kyiv
REMINDER_DEFAULT_HOUR=9
REMINDER_DEFAULT_MINUTE=0

DISCORD_TOKEN=

# Optional but recommended for instant slash-command registration while testing.
# Copy your Discord server/guild ID here.
DISCORD_GUILD_ID=
AUTO_JOIN_ENABLED=false
AUTO_JOIN_GUILD_ID=
AUTO_JOIN_VOICE_CHANNEL_ID=
AUTO_JOIN_TEXT_CHANNEL_ID=

# Groq API key from https://console.groq.com/keys
GROQ_API_KEY=

# Groq models.
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo
ACTION_PARSER_MODEL=llama-3.1-8b-instant
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MODEL=groq/compound
GROQ_AUTO_MODEL_FALLBACK=true
GROQ_MODEL_LIMIT_COOLDOWN_MS=600000
GROQ_MODEL_DISCOVERY_ENABLED=true
GROQ_MODEL_DISCOVERY_INTERVAL_MS=172800000
GROQ_MODEL_DISCOVERY_INITIAL_DELAY_MS=30000
GROQ_AUTO_SELECT_DISCOVERED_MODELS=true
GROQ_DISCOVERED_CHAT_LIMIT=8
GROQ_DISCOVERED_ACTION_LIMIT=6
GROQ_DISCOVERED_STT_LIMIT=4
GROQ_DISCOVERED_WEB_LIMIT=4
GROQ_CHAT_FALLBACK_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b,meta-llama/llama-4-scout-17b-16e-instruct,qwen/qwen3-32b,openai/gpt-oss-20b,llama-3.1-8b-instant
GROQ_ACTION_FALLBACK_MODELS=llama-3.1-8b-instant,openai/gpt-oss-20b,qwen/qwen3-32b,llama-3.3-70b-versatile
GROQ_STT_FALLBACK_MODELS=whisper-large-v3-turbo,whisper-large-v3
GROQ_WEB_FALLBACK_MODELS=groq/compound,groq/compound-mini

# Optional Telegram bridge. Recommended setup is through Discord /telegram_setup,
# because the token is entered in a private Discord modal instead of a channel message.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_INBOUND_ENABLED=false
TELEGRAM_INBOUND_ALLOWED_CHAT_IDS=
TELEGRAM_INBOUND_PLAIN_FORWARD=false
TELEGRAM_INBOUND_POLL_MS=7000

# Heavy task queues. They keep slow web/AI/TTS/Telegram/backup/soundboard work from running all at once.
HEAVY_TASK_MAX_PENDING=120
HEAVY_TASK_SLOW_MS=15000
AI_TASK_CONCURRENCY=2
WEB_SEARCH_TASK_CONCURRENCY=1
TTS_TASK_CONCURRENCY=1
TELEGRAM_TASK_CONCURRENCY=1
BACKUP_TASK_CONCURRENCY=1
SOUNDBOARD_TASK_CONCURRENCY=1

IDLE_CHATTER_ENABLED=false
IDLE_CHATTER_MINUTES=5
IDLE_CHATTER_USE_WEB=true
IDLE_CHATTER_STYLE=mixed
IDLE_LEAVE_ENABLED=true
IDLE_LEAVE_MINUTES=60
IDLE_LEAVE_PHRASE=

# Whisper language hint. Russian is primary; English is allowed only for short terms, commands, nicks, or names.
STT_LANGUAGE=ru
STT_ALLOWED_LANGUAGES=ru,en
STT_LANGUAGE_HINT=Основная речь на русском. Английские слова допускаются только как короткие термины, команды, ники или названия.
STT_LANGUAGE_GUARD_ENABLED=true
STT_PROMPT_MAX_CHARS=420
STT_PROMPT_MAX_BYTES=780
STT_TRANSIENT_RETRIES=3
STT_WAKE_RETRY_ENABLED=true
STT_PROMPT=Русская речь в Discord. Английские слова только как отдельные термины, команды, ники и названия. Частые слова: Бот, bot, what, вот, от, робот, роботик, ботик, бота, боду, бод, bat, board, борт, войс, voice, channel, disconnect, mute, move, stream, screen, запомни, remember, remind, stop, хватит, остановись, харош, хорош.

# Voice assistant behavior.
ASSISTANT_NAME=Бот
BOT_WAKE_WORD=бот
BOT_WAKE_ALIASES=вот,от,робот,роботик,ботик,бота,боту,боте,боты,ботом,бод,бат,борт,вод,бо,ботт
BOT_WAKE_FUZZY=true
LISTEN_WITHOUT_WAKE_WORD=false
WAKE_ACK_AI_ENABLED=true
WAKE_ACK_MAX_CHARS=32
WAKE_ACK_FALLBACK_PHRASES=Слушаю,Говори,На связи,Да, я тут,Внимательно,Давай,Жду вопрос
ACTIVE_DIALOGUE_ENABLED=false
ACTIVE_DIALOGUE_SECONDS=45
CONFIRM_DANGEROUS_ACTIONS=false
MAX_REPLY_CHARS=650
VOICE_REPLY_MAX_CHARS=450
VOICE_TEXT_OUTPUT_MODE=thread
SILENT_MESSAGES=true
SILENCE_MS=900
MAX_UTTERANCE_MS=8000
POST_WAKE_SILENCE_MS=1200
POST_WAKE_MAX_UTTERANCE_MS=20000
MIN_AUDIO_MS=350
MIN_RMS=60
WAKE_LISTEN_WINDOW_MS=15000
REPLY_COOLDOWN_MS=900
IGNORE_AFTER_JOIN_MS=500
STREAM_DISABLE_RESTORE_MS=8000
STREAM_DISABLE_VERIFY_DELAY_MS=1500
PRESENCE_ANNOUNCEMENTS_ENABLED=true
PRESENCE_ANNOUNCEMENT_DELAY_MS=900
PRESENCE_ANNOUNCEMENT_COOLDOWN_MS=25000
PRESENCE_ANNOUNCEMENT_QUIET_WAIT_MS=8000
PRESENCE_NAME_ANNOUNCEMENT_MAX_MEMBERS=2
PRESENCE_BOT_JOIN_NAMED_MAX_MEMBERS=3
PRESENCE_MEMBER_GREETING_COOLDOWN_MS=43200000
PRESENCE_ANNOUNCEMENT_MAX_CHARS=60
VOICE_DEBUG=false
API_LIMIT_ALERT_THRESHOLDS=15,5
API_LIMIT_ALERT_RESET_PERCENT=50

# Local persistent memory/reminders.
# In Docker this should stay /app/data because docker-compose mounts it as a volume.
DATA_DIR=./data
MAX_MEMORY_ITEMS=200
MEMORY_CONTEXT_LIMIT=8
MAX_REMINDER_ITEMS=200

# Portable backups from the active storage.
# BACKUP_TARGET_PATH can be local path, file://, ftp://host/path, or smb://host/share/path.
# For SMB the first path segment is the share name, e.g. smb://192.168.0.1/G/Discord AI Bot Backups
BACKUP_ENABLED=false
BACKUP_TARGET_PATH=/app/data/backups
BACKUP_TARGET_USERNAME=
BACKUP_TARGET_PASSWORD=
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION=2
BACKUP_IDLE_ONLY=true
BACKUP_EVENT_LIMIT=5000
BACKUP_TRANSPORT_TIMEOUT_SECONDS=45

# Full system backups created by scripts/backup.sh and scripts/update.sh.
# Keeps only the newest two backup folders and archives by default.
BACKUP_ARCHIVE_RETENTION=2

# Storage.
# Docker default is mysql with the db service from docker-compose.yml.
# For bare local Node.js runs without Docker you can temporarily set STORAGE_DRIVER=json.
# First MySQL start migrates existing DATA_DIR/state.json and runtime-config.json automatically.
STORAGE_DRIVER=mysql
STORAGE_FALLBACK_JSON=true
DB_HOST=db
DB_PORT=3306
DB_NAME=discord_ai_assistant
DB_USER=assistant
DB_PASSWORD=assistant_change_me
DB_ROOT_PASSWORD=root_change_me
DB_CONNECTION_LIMIT=5
DB_CONNECT_ATTEMPTS=45
DB_MIGRATE_FROM_JSON=true

# Web admin panel.
# Keep it non-empty if the panel is exposed outside localhost.
PANEL_PASSWORD=
PANEL_HOST=127.0.0.1
PANEL_BIND_HOST=127.0.0.1
PANEL_PORT=8787
PANEL_SESSION_MAX_AGE_SECONDS=43200
PANEL_LOGIN_MAX_ATTEMPTS=6
PANEL_LOGIN_WINDOW_MS=600000
PANEL_LOGIN_LOCK_MS=300000

# Text-to-speech.
# "edge" uses Microsoft Edge Neural online voices through edge-tts.
# "macos" works locally on macOS using the built-in `say` command.
# "espeak" works in Docker/Linux with espeak-ng + ffmpeg.
TTS_PROVIDER=edge
EDGE_TTS_COMMAND=
EDGE_TTS_VOICE=ru-RU-SvetlanaNeural
EDGE_TTS_ENGLISH_VOICE=en-US-AvaMultilingualNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz
MACOS_TTS_VOICE=Milena
ESPEAK_TTS_VOICE=ru
ESPEAK_TTS_SPEED=165

# Music/radio player.
# Docker image already includes yt-dlp at /opt/media-tools/bin/yt-dlp.
MUSIC_YT_DLP_COMMAND=
MUSIC_DEFAULT_VOLUME=0.45
MUSIC_MAX_QUEUE=25
MUSIC_SEARCH_TIMEOUT_MS=25000
